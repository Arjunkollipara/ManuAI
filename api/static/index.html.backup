<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ManuAI | Manufacturing Intelligence Platform</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js" integrity="sha512-3qYVHS6BXkLXE2vYtkfwYQX2SjDXol8tWlJ6iuY03h9Tm/Cw2P5+Y+T7kHEE3NVVlPZypY8lrQhQ2tS+IM+7Cg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  <style>
    :root {
      color-scheme: dark;
      --bg-primary: #0a0e1a;
      --bg-secondary: #111827;
      --bg-card: rgba(26, 34, 52, 0.88);
      --bg-card-strong: #111827;
      --bg-card-hover: rgba(30, 42, 66, 0.95);
      --accent-cyan: #00d4ff;
      --accent-cyan-dim: #0099bb;
      --accent-amber: #f59e0b;
      --accent-amber-dim: #d97706;
      --accent-green: #10b981;
      --accent-red: #ef4444;
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --text-muted: #475569;
      --border: #1e3a5f;
      --glow-cyan: 0 0 20px rgba(0, 212, 255, 0.25);
      --glow-amber: 0 0 20px rgba(245, 158, 11, 0.25);
      --shadow: 0 20px 70px rgba(0,0,0,0.35);
      --radius: 24px;
      font-family: 'Inter', sans-serif;
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; min-height: 100%; color: var(--text-primary); overflow-x: hidden; }
    body { font-feature-settings: 'ss01' 1; background-color: #0a0e1a; }
    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }
    button, input, select, textarea { font: inherit; }

    .app-shell { min-height: 100vh; display: flex; flex-direction: column; position: relative; z-index: 1; width: 100%; background-color: #0a0e1a; }

    #navbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 64px;
      background: rgba(10, 14, 26, 0.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0, 212, 255, 0.15);
      z-index: 1000;
      display: flex;
      align-items: center;
    }

    .nav-container {
      max-width: 1400px;
      width: 100%;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
    }

    .brand-name {
      font-size: 1.25rem;
      font-weight: 700;
      color: #f1f5f9;
      letter-spacing: 0.05em;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .nav-link {
      padding: 8px 16px;
      border-radius: 6px;
      color: #94a3b8;
      text-decoration: none;
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s ease;
      border-bottom: 2px solid transparent;
    }

    .nav-link:hover {
      color: #f1f5f9;
      background: rgba(0, 212, 255, 0.08);
    }

    .nav-link.active {
      color: #00d4ff;
      border-bottom-color: #00d4ff;
      text-shadow: 0 0 12px rgba(0, 212, 255, 0.5);
    }

    .nav-status {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.75rem;
      color: #94a3b8;
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #475569;
      transition: background 0.3s ease;
    }

    .status-dot.online {
      background: #10b981;
      box-shadow: 0 0 8px rgba(16, 185, 129, 0.6);
      animation: pulse-green 2s infinite;
    }

    .status-dot.offline {
      background: #ef4444;
    }

    @keyframes pulse-green {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }
    .nav-link { position: relative; color: var(--text-secondary); font-weight: 500; cursor: pointer; transition: color 0.25s ease; }
    .nav-link.active, .nav-link:hover { color: var(--accent-cyan); }
    .nav-link.active::after { content: ''; position: absolute; left: 0; bottom: -10px; width: 100%; height: 2px; background: linear-gradient(90deg, var(--accent-cyan), rgba(0,212,255,0.5)); box-shadow: var(--glow-cyan); border-radius: 999px; }

    .page { display: none; width: 100%; min-height: 100vh; padding: 84px 24px 40px 24px; box-sizing: border-box; max-width: 1400px; margin: 0 auto; position: relative; z-index: 1; }
    .page.active { display: block; }
    .content-grid { max-width: 1440px; margin: 0 auto; display: grid; gap: 24px; }
    .hero-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 32px; align-items: center; min-height: calc(100vh - 100px); padding-top: 40px; }

    .eyebrow { display: inline-flex; align-items: center; gap: 10px; color: var(--accent-cyan); text-transform: uppercase; letter-spacing: 0.18em; font-size: 0.78rem; font-weight: 700; }
    .eyebrow::before { content: ''; width: 12px; height: 12px; border-radius: 50%; background: rgba(0,212,255,0.15); box-shadow: 0 0 12px rgba(0,212,255,0.16); }
    .hero-title { font-size: clamp(3.4rem, 4.8vw, 5.6rem); line-height: 0.92; letter-spacing: -0.04em; margin: 0; }
    .hero-copy { margin: 24px 0 32px; max-width: 600px; color: var(--text-secondary); font-size: 1.04rem; line-height: 1.9; }
    .hero-actions { display: flex; gap: 18px; flex-wrap: wrap; }
    .btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; border: none; border-radius: 999px; padding: 16px 26px; background: linear-gradient(135deg, rgba(0,212,255,0.24), rgba(0,212,255,0.8)); color: #070e1d; font-weight: 700; cursor: pointer; box-shadow: 0 0 24px rgba(0,212,255,0.18); transition: transform 0.25s ease, background 0.25s ease; }
    .btn:hover { transform: translateY(-1px); background: linear-gradient(135deg, rgba(0,212,255,0.35), rgba(0,212,255,1)); }
    .btn-secondary { background: rgba(255,255,255,0.05); color: var(--text-primary); border: 1px solid rgba(255,255,255,0.08); }

    .hero-stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; margin-top: 32px; }
    .stat-card { padding: 24px; border-radius: var(--radius); position: relative; overflow: hidden; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); backdrop-filter: blur(18px); }
    .stat-card::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at top left, rgba(0,212,255,0.18), transparent 35%); pointer-events: none; opacity: 0.7; }
    .stat-label { color: var(--text-secondary); font-size: 0.9rem; letter-spacing: 0.09em; text-transform: uppercase; }
    .stat-value { margin-top: 14px; font-size: 2.15rem; font-weight: 800; color: #fff; font-family: 'JetBrains Mono', monospace; }
    .hero-preview { display: grid; gap: 18px; }
    .preview-card { position: relative; overflow: hidden; padding: 22px 20px; border-radius: 28px; background: rgba(23, 35, 60, 0.92); border: 1px solid rgba(0,212,255,0.08); backdrop-filter: blur(18px); transition: transform 0.35s ease, border 0.35s ease; box-shadow: 0 30px 70px rgba(0,0,0,0.18); }
    .preview-card:hover { transform: translateY(-6px); border-color: rgba(0,212,255,0.2); }
    .preview-icon { width: 48px; height: 48px; display: grid; place-items: center; border-radius: 16px; background: rgba(0,212,255,0.1); color: var(--accent-cyan); font-size: 1.25rem; }
    .preview-title { font-size: 1.05rem; font-weight: 700; margin: 16px 0 8px; }
    .preview-copy { color: var(--text-secondary); line-height: 1.7; font-size: 0.95rem; }

    .section-title { display: flex; align-items: center; justify-content: space-between; gap: 14px; }
    .section-title h2 { margin: 0; font-size: 1.6rem; letter-spacing: -0.03em; }
    .section-title small { color: var(--text-secondary); }
    .glass-card { background: var(--bg-card); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius); box-shadow: var(--shadow); backdrop-filter: blur(18px); padding: 28px; position: relative; overflow: hidden; transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease; }
    .glass-card:hover { transform: translateY(-4px); border-color: rgba(0,212,255,0.18); background: rgba(26,34,52,0.96); }
    .glass-card h3 { margin: 0 0 12px; font-size: 1.1rem; }
    .glass-card p { margin: 0; color: var(--text-secondary); line-height: 1.7; }
    .badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 12px; border-radius: 999px; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; }
    .badge.cyan { background: rgba(0,212,255,0.14); color: var(--accent-cyan); }
    .badge.green { background: rgba(16,185,129,0.14); color: var(--accent-green); }
    .badge.amber { background: rgba(245,158,11,0.14); color: var(--accent-amber); }
    .badge.red { background: rgba(239,68,68,0.13); color: var(--accent-red); }

    .card {
      background: rgba(26, 34, 52, 0.8);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(0, 212, 255, 0.1);
      border-radius: 12px;
      padding: 24px;
      transition: all 0.2s ease;
    }

    .card:hover {
      border-color: rgba(0, 212, 255, 0.3);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(0, 212, 255, 0.1);
    }

    .row-grid { display: grid; gap: 24px; }
    .dashboard-grid { grid-template-columns: repeat(12, minmax(0, 1fr)); }
    .col-span-8 { grid-column: span 8 / span 8; }
    .col-span-4 { grid-column: span 4 / span 4; }
    .col-span-12 { grid-column: span 12 / span 12; }
    .kpi-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 24px; }
    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .kpi-card { position: relative; overflow: hidden; }
    .kpi-card .icon { width: 42px; height: 42px; display: grid; place-items: center; border-radius: 14px; background: rgba(255,255,255,0.05); color: var(--accent-cyan); }
    .kpi-card .label { color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.78rem; margin-bottom: 14px; }
    .kpi-card .value { font-size: 2.1rem; font-weight: 800; margin: 0; font-family: 'JetBrains Mono', monospace; }
    .kpi-card .trend { display: inline-flex; align-items: center; gap: 8px; margin-top: 12px; font-size: 0.9rem; }
    .kpi-card .trend.up { color: var(--accent-green); }
    .kpi-card .trend.down { color: var(--accent-amber); }
    .chart-panel { display: grid; gap: 18px; }
    .chart-box { display: grid; gap: 18px; }
    .chart-wrapper { position: relative; padding: 22px; border-radius: 28px; background: rgba(17,24,39,0.94); border: 1px solid rgba(255,255,255,0.08); overflow: hidden; }
    .chart-label { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .chart-label h3 { margin: 0; font-size: 1rem; }
    .chart-label .pill { font-size: 0.78rem; padding: 7px 12px; background: rgba(15,23,42,0.88); border-radius: 999px; }
    canvas { width: 100% !important; height: auto !important; }

    .alert-feed { display: grid; gap: 14px; }
    .alert-row { display: grid; grid-template-columns: 120px 1fr 200px 110px; gap: 14px; align-items: center; padding: 18px 18px 18px 20px; background: rgba(17,24,39,0.96); border: 1px solid rgba(255,255,255,0.06); border-radius: 20px; transition: background 0.25s ease; }
    .alert-row.critical { border-color: rgba(239,68,68,0.35); animation: pulseAlert 2.4s infinite ease-in-out; }
    @keyframes pulseAlert { 0%,100% { transform: translateY(0); box-shadow: 0 0 0 rgba(239,68,68,0.08); } 50% { transform: translateY(-1px); box-shadow: 0 0 30px rgba(239,68,68,0.14); } }
    .alert-meta { display: flex; flex-direction: column; gap: 6px; }
    .alert-title { display: flex; align-items: center; gap: 12px; font-weight: 700; }
    .alert-copy { color: var(--text-secondary); font-size: 0.94rem; line-height: 1.7; }
    .alert-time { color: var(--text-muted); font-size: 0.9rem; }
    .alert-resolve { border: none; border-radius: 999px; padding: 12px 16px; color: var(--text-primary); background: rgba(0,212,255,0.1); cursor: pointer; transition: background 0.25s ease; }
    .alert-resolve:hover { background: rgba(0,212,255,0.18); }
    .alert-empty { display: grid; place-items: center; padding: 52px; background: rgba(16,24,40,0.92); border-radius: 28px; text-align: center; color: var(--text-secondary); }
    .alert-empty strong { color: var(--text-primary); display: block; margin-bottom: 12px; font-size: 1.15rem; }

    .predict-panel { display: grid; gap: 24px; }
    .predict-form { display: grid; gap: 18px; }
    .range-control { display: grid; gap: 8px; }
    .range-control label { display: flex; justify-content: space-between; gap: 16px; font-size: 0.95rem; color: var(--text-secondary); }
    .slider-row { display: grid; gap: 12px; }
    .slider-value { color: var(--text-primary); font-weight: 700; font-family: 'JetBrains Mono', monospace; }
    input[type=range] { width: 100%; accent-color: var(--accent-cyan); }
    .type-selector { display: flex; gap: 12px; }
    .type-pill { border: 1px solid rgba(255,255,255,0.08); padding: 12px 18px; border-radius: 999px; color: var(--text-secondary); cursor: pointer; transition: all 0.25s ease; background: rgba(255,255,255,0.03); }
    .type-pill.active { color: #fff; background: rgba(0,212,255,0.16); border-color: rgba(0,212,255,0.22); }
    .predict-submit { border: none; border-radius: 999px; padding: 16px 22px; background: linear-gradient(135deg, var(--accent-cyan), rgba(0,212,255,0.85)); color: #07101b; font-weight: 700; cursor: pointer; }
    .predict-result { padding: 24px; border-radius: 28px; background: rgba(17,24,39,0.96); border: 1px solid rgba(255,255,255,0.06); }
    .risk-gauge { display: grid; place-items: center; gap: 18px; }
    .gauge { width: 100%; max-width: 320px; height: 180px; }
    .risk-score { font-size: 3.5rem; font-weight: 800; font-family: 'JetBrains Mono', monospace; color: var(--text-primary); }
    .risk-copy { color: var(--text-secondary); margin: 0; }
    .factor-chart { min-height: 220px; }

    .prediction-page { display: grid; grid-template-columns: 1.2fr 1fr; gap: 24px; }
    .prediction-form-panel, .prediction-result-panel { display: grid; gap: 18px; }
    .prediction-history { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; min-width: 720px; }
    th, td { padding: 14px 16px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.07); }
    th { color: var(--text-secondary); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; }
    td { color: var(--text-primary); font-size: 0.95rem; }
    .table-badge { min-width: 82px; display: inline-flex; justify-content: center; }
    .table-badge.high { background: rgba(245,158,11,0.14); color: var(--accent-amber); }
    .table-badge.critical { background: rgba(239,68,68,0.14); color: var(--accent-red); }
    .table-badge.low { background: rgba(16,185,129,0.14); color: var(--accent-green); }

    .split-panel { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 24px; }
    .agent-selector { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; }
    .agent-card { padding: 20px; border-radius: 26px; background: rgba(17,24,39,0.96); border: 1px solid rgba(255,255,255,0.07); cursor: pointer; transition: transform 0.25s ease, border-color 0.25s ease; }
    .agent-card.active { border-color: rgba(0,212,255,0.35); box-shadow: 0 0 30px rgba(0,212,255,0.16); }
    .agent-card .agent-icon { width: 48px; height: 48px; display: grid; place-items: center; border-radius: 16px; background: rgba(255,255,255,0.05); font-size: 1.15rem; }
    .agent-name { margin: 18px 0 6px; font-size: 1rem; font-weight: 700; }
    .agent-tagline { color: var(--text-secondary); line-height: 1.7; }
    .chat-window { height: 560px; display: grid; gap: 18px; }
    .chat-box { flex: 1; padding: 20px; overflow-y: auto; background: rgba(17,24,39,0.92); border-radius: 26px; border: 1px solid rgba(255,255,255,0.08); }
    .message { display: grid; gap: 8px; max-width: 82%; }
    .message.agent { justify-self: start; padding: 18px 18px 18px 20px; border-radius: 24px; background: rgba(15,23,42,0.96); border-left: 4px solid var(--accent-cyan); }
    .message.user { justify-self: end; background: linear-gradient(135deg, rgba(0,212,255,0.14), rgba(0,212,255,0.24)); color: #e9fbff; border-radius: 24px 24px 12px 24px; align-items: end; }
    .message-meta { display: flex; align-items: center; justify-content: space-between; gap: 12px; color: var(--text-muted); font-size: 0.82rem; }
    .typing-dots { display: flex; gap: 8px; align-items: center; }
    .typing-dots span { width: 10px; height: 10px; border-radius: 999px; background: rgba(0,212,255,0.7); animation: bounceDot 0.9s ease-in-out infinite; }
    .typing-dots span:nth-child(2) { animation-delay: 0.15s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.3s; }
    @keyframes bounceDot { 0%,100% { transform: translateY(0); opacity: 0.4; } 50% { transform: translateY(-5px); opacity: 1; } }
    .chat-input { display: grid; gap: 14px; padding: 18px; border-radius: 26px; background: rgba(17,24,39,0.94); border: 1px solid rgba(255,255,255,0.08); }
    .chat-input textarea { width: 100%; min-height: 90px; resize: vertical; padding: 18px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); background: rgba(14,18,31,0.92); color: #f8fafc; }
    .chat-controls { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; justify-content: space-between; }
    .chips { display: flex; flex-wrap: wrap; gap: 10px; }
    .chip { border-radius: 999px; background: rgba(255,255,255,0.05); padding: 10px 14px; cursor: pointer; transition: background 0.2s ease; }
    .chip:hover { background: rgba(0,212,255,0.12); }
    .send-btn { border: none; border-radius: 999px; padding: 14px 18px; background: var(--accent-cyan); color: #07101b; cursor: pointer; }

    .context-sidebar { display: grid; gap: 18px; }
    .status-card { padding: 20px; border-radius: 26px; background: rgba(17,24,39,0.96); border: 1px solid rgba(255,255,255,0.08); }
    .status-card h3 { margin: 0 0 12px; font-size: 1rem; }
    .status-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; color: var(--text-secondary); margin-bottom: 12px; }
    .status-label { color: var(--text-secondary); }

    .search-shell { display: grid; gap: 24px; }
    .search-bar { display: flex; gap: 14px; align-items: center; width: 100%; }
    .search-bar input { flex: 1; border: 1px solid rgba(255,255,255,0.1); border-radius: 999px; padding: 18px 22px; background: rgba(15,23,42,0.95); color: #f8fafc; outline: none; }
    .search-bar button { width: 68px; height: 68px; border-radius: 50%; border: none; background: rgba(0,212,255,0.18); color: #fff; cursor: pointer; }
    .search-suggestions { display: flex; flex-wrap: wrap; gap: 12px; }
    .pill { padding: 12px 16px; border-radius: 999px; background: rgba(255,255,255,0.05); color: var(--text-secondary); cursor: pointer; transition: background 0.25s ease; }
    .pill:hover { background: rgba(0,212,255,0.12); }
    .result-card { padding: 22px; border-radius: 26px; background: rgba(17,24,39,0.96); border: 1px solid rgba(255,255,255,0.07); display: grid; gap: 12px; }
    .result-title { display: flex; justify-content: space-between; align-items: center; gap: 12px; }
    .result-title small { color: var(--text-secondary); }
    .result-copy { color: var(--text-secondary); line-height: 1.7; }
    .result-actions { display: flex; gap: 12px; flex-wrap: wrap; }
    .result-btn { border: none; border-radius: 999px; padding: 10px 16px; background: rgba(0,212,255,0.1); color: #fff; cursor: pointer; }

    .status-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; }
    .service-card { padding: 22px; border-radius: 26px; background: rgba(17,24,39,0.96); border: 1px solid rgba(255,255,255,0.08); display: grid; gap: 14px; }
    .status-pill { border-radius: 999px; padding: 8px 12px; font-size: 0.82rem; display: inline-flex; align-items: center; gap: 8px; }
    .status-dot { width: 10px; height: 10px; border-radius: 999px; display: inline-block; }
    .status-good .status-dot { background: var(--accent-green); }
    .status-deg .status-dot { background: var(--accent-amber); }
    .status-down .status-dot { background: var(--accent-red); }
    .config-table { width: 100%; border-collapse: collapse; }
    .config-table td { padding: 12px 14px; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .config-key { color: var(--text-secondary); width: 45%; }
    .config-val { text-align: right; }

    .hero-badge { display: inline-flex; gap: 10px; padding: 10px 18px; background: rgba(255,255,255,0.05); border-radius: 999px; color: var(--accent-cyan); font-size: 0.9rem; }
    .card-row { display: grid; gap: 20px; }
    .card-row-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .glow-border { position: absolute; inset: 0; border-radius: inherit; pointer-events: none; opacity: 0; transition: opacity 0.25s ease; box-shadow: inset 0 0 40px rgba(0,212,255,0.12); }
    .glass-card:hover .glow-border { opacity: 1; }

    .hero-visual { position: relative; min-height: 520px; display: grid; place-items: center; border-radius: 36px; overflow: hidden; background: rgba(16,24,40,0.96); border: 1px solid rgba(255,255,255,0.08); }
    .hero-visual::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 18%, rgba(0,212,255,0.10), transparent 32%), linear-gradient(180deg, rgba(255,255,255,0.05), transparent 60%); pointer-events: none; }
    .hero-wave { position: absolute; inset: 0; opacity: 0.35; background-image: radial-gradient(circle, rgba(0,212,255,0.18) 1px, transparent 1px); background-size: 24px 24px; animation: drift 16s linear infinite; }
    @keyframes drift { from { transform: translate(0,0); } to { transform: translate(-24px,24px); } }
    .hero-preview-stack { position: absolute; inset: 20px; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; pointer-events: none; }
    .preview-float { animation: floatUpDown 8s ease-in-out infinite; }
    .preview-float:nth-child(2) { animation-delay: 0.9s; }
    .preview-float:nth-child(3) { animation-delay: 1.6s; }
    @keyframes floatUpDown { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-16px); } }

    .panel-inner { display: grid; gap: 18px; }
    .meter-legend { display: flex; gap: 10px; flex-wrap: wrap; }
    .meter-legend span { display: inline-flex; align-items: center; gap: 8px; font-size: 0.85rem; color: var(--text-secondary); }
    .meter-legend .dot { width: 10px; height: 10px; border-radius: 999px; display: inline-block; }

    .toggle-pill { display: inline-flex; align-items: center; gap: 10px; padding: 10px 16px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.08); cursor: pointer; }
    .toggle-pill input { accent-color: var(--accent-cyan); }
    .status-meta { display: grid; gap: 12px; }
    .status-row-inner { display: flex; justify-content: space-between; gap: 16px; }
    .status-row-inner strong { color: #fff; }
    .status-caption { color: var(--text-secondary); font-size: 0.95rem; }
    .small-pill { background: rgba(255,255,255,0.05); padding: 10px 14px; border-radius: 999px; color: var(--text-secondary); font-size: 0.84rem; display: inline-flex; align-items: center; gap: 8px; }

    .footer { margin-top: 60px; padding-bottom: 24px; color: var(--text-secondary); text-align: center; font-size: 0.9rem; }

    @media (max-width: 1260px) { .hero-grid, .prediction-page, .split-panel { grid-template-columns: 1fr; } .kpi-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } .status-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 860px) { .nav-container { padding: 0 16px; } .nav-links { gap: 4px; } .hero-grid { gap: 24px; } .kpi-grid { grid-template-columns: 1fr; } .status-grid { grid-template-columns: 1fr; } .search-bar { flex-direction: column; align-items: stretch; } .search-bar button { width: 100%; } .search-suggestions { justify-content: center; } }
    @media (max-width: 660px) { .brand { justify-content: center; } .hero-title { font-size: 2.35rem; } .hero-stats { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="app-shell">
    <nav id="navbar">
      <div class="nav-container">
        <div class="nav-brand">
          <svg width="24" height="24" viewBox="0 0 24 24" 
               fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 7L12 12L22 7L12 2Z" 
                  stroke="#00d4ff" stroke-width="2" 
                  stroke-linejoin="round"/>
            <path d="M2 17L12 22L22 17" 
                  stroke="#00d4ff" stroke-width="2" 
                  stroke-linejoin="round"/>
            <path d="M2 12L12 17L22 12" 
                  stroke="#00d4ff" stroke-width="2" 
                  stroke-linejoin="round"/>
          </svg>
          <span class="brand-name">ManuAI</span>
        </div>
        <div class="nav-links">
          <a class="nav-link active" data-page="heroPage">
            Home
          </a>
          <a class="nav-link" data-page="dashboardPage">
            Dashboard
          </a>
          <a class="nav-link" data-page="predictPage">
            Predict
          </a>
          <a class="nav-link" data-page="agentsPage">
            Agents
          </a>
          <a class="nav-link" data-page="searchPage">
            Search
          </a>
          <a class="nav-link" data-page="statusPage">
            Status
          </a>
        </div>
        <div class="nav-status">
          <span class="status-dot" id="apiStatusDot"></span>
          <span class="status-text" id="apiStatusText">
            Connecting...
          </span>
        </div>
      </div>
    </nav>

    <main class="content-grid">
      <section id="heroPage" class="page">
        <div class="hero-grid">
          <div>
            <span class="eyebrow">Manufacturing Intelligence</span>
            <h1 class="hero-title">Manufacturing Intelligence Platform</h1>
            <p class="hero-copy">AI-powered predictive maintenance and quality operations crafted for industrial control, analytics, and frontline decision making.</p>
            <div class="hero-actions">
              <button class="btn" id="enterPlatformBtn">Enter Platform</button>
              <button class="btn btn-secondary" id="heroDemoBtn">Explore Dashboard</button>
            </div>
            <div class="hero-stats">
              <div class="stat-card"><div class="stat-label">Model Accuracy</div><div class="stat-value" data-count="99.7">0%</div></div>
              <div class="stat-card"><div class="stat-label">Readings Analyzed</div><div class="stat-value" data-count="10000">0</div></div>
              <div class="stat-card"><div class="stat-label">Intelligent Agents</div><div class="stat-value" data-count="3">0</div></div>
            </div>
          </div>
          <div class="hero-visual">
            <div class="hero-preview-stack">
              <div class="preview-card preview-float"><div class="preview-icon">🛠</div><div class="preview-title">Defect Classification</div><p class="preview-copy">Detect probable production defects before they impact assembly lines and yield.</p></div>
              <div class="preview-card preview-float"><div class="preview-icon">📈</div><div class="preview-title">Production Optimization</div><p class="preview-copy">Optimize throughput with predictive cycle tuning and machine efficiency insights.</p></div>
              <div class="preview-card preview-float"><div class="preview-icon">🔧</div><div class="preview-title">Maintenance Insights</div><p class="preview-copy">Automated SOP guidance, agent-driven troubleshooting, and asset health visibility.</p></div>
            </div>
          </div>
        </div>
      </section>

      <section id="dashboardPage" class="page active">
        <div class="section-title"><h2>Dashboard</h2><small>Real-time operational health and risk view</small></div>
        <div class="kpi-grid">
          <div class="glass-card kpi-card" id="kpiReadings"><div class="icon">📡</div><div class="label">Total Sensor Readings</div><div class="value">—</div><div class="trend up" id="trendingReadings">+12.4%</div></div>
          <div class="glass-card kpi-card" id="kpiAlerts"><div class="icon">⚠️</div><div class="label">Active Alerts</div><div class="value">—</div><div class="trend down" id="trendingAlerts">+8.2%</div></div>
          <div class="glass-card kpi-card" id="kpiFailure"><div class="icon">⛽</div><div class="label">Failure Rate</div><div class="value">—</div><div class="trend" id="trendingFailure">—</div></div>
          <div class="glass-card kpi-card"><div class="icon">🧠</div><div class="label">Model Accuracy</div><div class="value">99.7%</div><div class="trend up">Stable</div></div>
        </div>

        <div class="charts-grid">
          <div class="chart-panel">
            <div class="chart-wrapper glass-card"><div class="chart-label"><h3>Machine Risk Distribution</h3><span class="pill">Last 20 predictions</span></div><canvas id="riskDoughnut"></canvas></div>
          </div>
          <div class="chart-panel">
            <div class="chart-wrapper glass-card"><div class="chart-label"><h3>Sensor Readings Over Time</h3><span class="pill">Torque & Speed</span></div><canvas id="sensorLine"></canvas></div>
          </div>

          <div class="col-span-12 glass-card alert-section">
            <div class="section-title"><h2>Live Alert Feed</h2><small>Auto-refreshing every 30 seconds</small></div>
            <div id="alertFeed" class="alert-feed"></div>
          </div>

          <div class="col-span-12 glass-card predict-panel">
            <div class="section-title"><h2>Quick Failure Prediction</h2><small>Instant assessment from real sensor inputs</small></div>
            <div class="grid" style="display:grid;grid-template-columns:1.1fr 0.9fr; gap:24px;">
              <div class="predict-form">
                <div class="type-selector" id="quickTypeButtons"></div>
                <div class="range-control"><label>Air Temperature <span class="slider-value" id="quickAirValue">305 K</span></label><input type="range" min="290" max="320" value="305" id="quickAir"></div>
                <div class="range-control"><label>Process Temperature <span class="slider-value" id="quickProcessValue">315 K</span></label><input type="range" min="300" max="330" value="315" id="quickProcess"></div>
                <div class="range-control"><label>Rotational Speed <span class="slider-value" id="quickSpeedValue">1800 RPM</span></label><input type="range" min="500" max="3000" value="1800" id="quickSpeed"></div>
                <div class="range-control"><label>Torque <span class="slider-value" id="quickTorqueValue">50 Nm</span></label><input type="range" min="0" max="100" value="50" id="quickTorque"></div>
                <div class="range-control"><label>Tool Wear <span class="slider-value" id="quickWearValue">120 min</span></label><input type="range" min="0" max="300" value="120" id="quickWear"></div>
                <button class="predict-submit" id="quickPredictBtn">Predict Now</button>
              </div>
              <div class="predict-result" id="quickResultPanel">
                <div class="risk-gauge"><svg class="gauge" viewBox="0 0 320 180"></svg><div class="risk-score" id="quickRiskScore">—%</div><p class="risk-copy" id="quickRiskText">Run a prediction to see risk level.</p></div>
                <div class="meter-legend"><span><span class="dot" style="background:var(--accent-green)"></span> Top factors</span></div>
                <canvas id="quickFactors" class="factor-chart"></canvas>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="predictPage" class="page">
        <div class="section-title"><h2>Predictions</h2><small>Machine risk analysis and prediction history</small></div>
        <div class="prediction-page">
          <div class="prediction-form-panel glass-card">
            <h3>Prediction Inputs</h3>
            <div class="range-control"><label>Type</label><div class="type-selector" id="fullTypeButtons"></div></div>
            <div class="range-control"><label>Air Temperature <span class="slider-value" id="fullAirValue">305 K</span></label><input type="range" min="290" max="320" value="305" id="fullAir"></div>
            <div class="range-control"><label>Process Temperature <span class="slider-value" id="fullProcessValue">315 K</span></label><input type="range" min="300" max="330" value="315" id="fullProcess"></div>
            <div class="range-control"><label>Rotational Speed <span class="slider-value" id="fullSpeedValue">1800 RPM</span></label><input type="range" min="500" max="3000" value="1800" id="fullSpeed"></div>
            <div class="range-control"><label>Torque <span class="slider-value" id="fullTorqueValue">50 Nm</span></label><input type="range" min="0" max="100" value="50" id="fullTorque"></div>
            <div class="range-control"><label>Tool Wear <span class="slider-value" id="fullWearValue">120 min</span></label><input type="range" min="0" max="300" value="120" id="fullWear"></div>
            <button class="predict-submit" id="fullPredictBtn">Analyze Machine</button>
          </div>
          <div class="prediction-result-panel">
            <div class="glass-card"><h3>Risk Gauge</h3><svg class="gauge" viewBox="0 0 320 180" id="fullRiskGauge"></svg><div class="badge" id="fullRiskBadge">Awaiting input</div><p class="risk-copy" id="fullPredictionSummary">Submit a prediction to review risk and factor impact.</p></div>
            <div class="glass-card"><h3>Top Contributing Factors</h3><canvas id="fullFactorChart" style="min-height:220px"></canvas></div>
          </div>
        </div>
        <div class="glass-card prediction-history"><div class="section-title"><h3>Prediction History</h3><small>Recent machine assessments</small></div><div style="overflow-x:auto;"><table><thead><tr><th>ID</th><th>Risk Level</th><th>Probability</th><th>Failure Predicted</th><th>Timestamp</th></tr></thead><tbody id="historyTable"></tbody></table></div></div>
      </section>

      <section id="agentsPage" class="page">
        <div class="section-title"><h2>Agent Chat</h2><small>AI support for maintenance, analytics, and model operations</small></div>
        <div class="split-panel">
          <div>
            <div class="agent-selector" id="agentCards"></div>
            <div class="chat-window">
              <div class="chat-box" id="chatBox"></div>
              <div class="chat-input">
                <textarea id="chatInput" placeholder="Ask the platform a maintenance or operations question..."></textarea>
                <div class="chat-controls"><div class="chips" id="chatChips"></div><button class="send-btn" id="chatSendBtn">Send</button></div>
              </div>
            </div>
          </div>
          <div class="context-sidebar">
            <div class="status-card"><h3>Agent Status</h3><div class="status-row-inner"><span>Active Agent</span><strong id="currentAgentName">Maintenance Technician</strong></div><p class="status-caption" id="agentCapability">SOPs & Repair Procedures</p></div>
            <div class="status-card"><h3>Response Metadata</h3><div class="status-row"><span>Agent</span><strong id="agentUsed">MaintenanceAgent</strong></div><div class="status-row"><span>Status</span><strong id="agentStatus">Ready</strong></div><div class="status-row"><span>Response time</span><strong id="agentLatency">—</strong></div></div>
            <div class="status-card"><h3>Agent Capabilities</h3><div class="status-meta"><div class="small-pill">Maintenance SOPs</div><div class="small-pill">Production Insights</div><div class="small-pill">Model Explanation</div><div class="small-pill">Failure Analysis</div></div></div>
          </div>
        </div>
      </section>

      <section id="searchPage" class="page">
        <div class="section-title"><h2>Document Search</h2><small>Search maintenance manuals and SOP knowledge</small></div>
        <div class="search-shell glass-card">
          <div class="search-bar"><input id="docSearchInput" placeholder="Search maintenance manuals, SOPs, technical guides..."/><button id="docSearchBtn">🔎</button></div>
          <div class="search-suggestions" id="searchSuggestions"></div>
          <div id="searchResults" class="glass-card" style="padding:0; background:transparent; border:none;"></div>
        </div>
      </section>

      <section id="statusPage" class="page">
        <div class="section-title"><h2>System Status</h2><small>Infrastructure readiness and services overview</small></div>
        <div class="status-grid">
          <div class="service-card"><h3>FastAPI Backend</h3><div class="status-row"><span>Status</span><strong id="svcBackend">—</strong></div><div class="status-row"><span>Last checked</span><strong id="svcBackendAt">—</strong></div></div>
          <div class="service-card"><h3>Database</h3><div class="status-row"><span>Status</span><strong id="svcDatabase">—</strong></div><div class="status-row"><span>Last checked</span><strong id="svcDatabaseAt">—</strong></div></div>
          <div class="service-card"><h3>ML Model</h3><div class="status-row"><span>Status</span><strong id="svcModel">Loaded</strong></div><div class="status-row"><span>Recall</span><strong>0.973</strong></div><div class="status-row"><span>F1</span><strong>0.980</strong></div></div>
          <div class="service-card"><h3>RAG Pipeline</h3><div class="status-row"><span>Status</span><strong id="svcRag">—</strong></div><div class="status-row"><span>Indexed</span><strong id="svcRagCount">—</strong></div></div>
          <div class="service-card"><h3>Agent System</h3><div class="status-row"><span>Status</span><strong id="svcAgent">—</strong></div><div class="status-row"><span>Configured</span><strong id="svcAgentConf">—</strong></div></div>
          <div class="service-card"><h3>Azure Services</h3><div class="status-row"><span>OpenAI</span><strong id="svcAzureOpenAI">—</strong></div><div class="status-row"><span>Search</span><strong id="svcAzureSearch">—</strong></div><div class="status-row"><span>Key Vault</span><strong id="svcAzureKeyVault">—</strong></div></div>
        </div>
        <div class="glass-card status-card"><h3>Environment Configuration</h3><table class="config-table"><tbody id="configTable"></tbody></table><button class="predict-submit" id="refreshStatusBtn">Refresh Status</button></div>
      </section>
    </main>

    <footer class="footer">ManuAI Industrial Operations Platform • Powered by FastAPI, Chart.js, Anime.js</footer>
  </div>

  <script>
// ================================================
// CONFIGURATION
// ================================================
const API = window.location.origin;
const API_BASE = API;
const AGENT_TIMEOUT = 60000;
const DEFAULT_TIMEOUT = 10000;

    function showFatal(message) {
      try {
        let el = document.getElementById('fatalBanner');
        if (!el) {
          el = document.createElement('div');
          el.id = 'fatalBanner';
          el.style.cssText = 'position:fixed;left:16px;right:16px;bottom:16px;z-index:99999;padding:12px 14px;border-radius:12px;background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.35);color:#f1f5f9;font-family:Inter,system-ui,Segoe UI,sans-serif;font-size:12px;backdrop-filter:blur(10px);max-height:35vh;overflow:auto;white-space:pre-wrap;';
          document.body.appendChild(el);
        }
        el.textContent = message;
      } catch (_) {}
    }

    window.addEventListener('error', (e) => {
      showFatal(`UI JS error: ${e.message}\n${e.filename || ''}:${e.lineno || ''}:${e.colno || ''}`);
    });
    window.addEventListener('unhandledrejection', (e) => {
      showFatal(`UI promise rejection: ${String(e.reason || e)}`);
    });

    const state = {
      type: 'M',
      fullType: 'M',
      agentKey: 'maintenance',
      activeAgent: 'Maintenance Technician'
    };

    const NAV_ITEMS = [
      { label: 'Home', page: 'heroPage' },
      { label: 'Dashboard', page: 'dashboardPage' },
      { label: 'Predict', page: 'predictPage' },
      { label: 'Agents', page: 'agentsPage' },
      { label: 'Search', page: 'searchPage' },
      { label: 'Status', page: 'statusPage' }
    ];

    function createNav() {
      // Wire nav links - they already exist in HTML
      document.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          navigate(link.dataset.page);
        });
      });
      
      // Wire brand logo
      const brand = document.querySelector('.nav-brand');
      if (brand) {
        brand.addEventListener('click', () => navigate('heroPage'));
      }
    }

    function navigate(pageId) {
      // Hide all pages
      document.querySelectorAll('.page').forEach(p => {
        p.classList.remove('active');
        p.style.display = 'none';
      });

      // Show target page
      const target = document.getElementById(pageId);
      if (target) {
        target.classList.add('active');
        target.style.display = 'block';
      }

      // Update navbar active state (single pass)
      document.querySelectorAll('.nav-link').forEach(link => {
        link.classList.remove('active');
        if (link.dataset.page === pageId) link.classList.add('active');
      });

      window.scrollTo(0, 0);

      // Trigger page-specific loaders
      if (pageId === 'dashboardPage') setTimeout(() => { try { fetchDashboard(); } catch(e){} }, 0);
      if (pageId === 'predictPage')   setTimeout(() => { try { fetchPredictHistory(); } catch(e){} }, 0);
      if (pageId === 'agentsPage')    setTimeout(() => { try { loadAgentChat(); } catch(e){} }, 0);
      if (pageId === 'statusPage')    setTimeout(() => { try { refreshSystemStatus(); } catch(e){} }, 0);
    }

    function animateCounters() {
      document.querySelectorAll('[data-count]').forEach(el => {
        const target = Number(el.dataset.count);
        const duration = 1500;
        const start = 0;
        const startTime = performance.now();
        function tick(time) {
          const progress = Math.min((time - startTime) / duration, 1);
          const value = start + (target - start) * easeOutCubic(progress);
          el.textContent = target % 1 === 0 ? Math.round(value) : value.toFixed(1);
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      });
    }

    function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }

    function setRangeControls(ids) {
      ids.forEach(id => {
        const range = document.getElementById(id);
        if (!range) return;
        const labelId = id + 'Value';
        const label = document.getElementById(labelId);
        if (!label) return;
        const unit = id.toLowerCase().includes('speed') ? ' RPM' : id.toLowerCase().includes('wear') ? ' min' : ' K';
        label.textContent = range.value + unit;
        range.addEventListener('input', () => { label.textContent = range.value + unit; });
      });
    }

    function buildHero() {
      animateCounters();
    }

    function createTypeButtons(target, prefix) {
      const container = document.getElementById(target);
      ['L','M','H'].forEach(type => {
        const pill = document.createElement('div');
        pill.className = 'type-pill' + (state[prefix] === type ? ' active' : '');
        pill.textContent = type;
        pill.addEventListener('click', () => {
          state[prefix] = type;
          container.querySelectorAll('.type-pill').forEach(btn => btn.classList.toggle('active', btn.textContent === type));
        });
        container.appendChild(pill);
      });
    }

    async function fetchDashboard() {
      const stats = await safeFetch(`${API_BASE}/ingest/stats`, { total_readings: 0, total_alerts: 0, failure_rate_percent: 0 });
      const history = await safeFetch(`${API_BASE}/predict/history?limit=20`, []);
      const readings = await safeFetch(`${API_BASE}/ingest/sensor-data?limit=20`, []);
      updateKpi(stats);
      buildRiskChart(history);
      buildSensorChart(readings);
      buildAlerts();
      animateActiveAlerts();
    }

    function updateKpi(stats) {
      document.querySelector('#kpiReadings .value').textContent = stats.total_readings || '0';
      document.querySelector('#kpiAlerts .value').textContent = stats.total_alerts || '0';
      const failure = stats.failure_rate_percent || 0;
      const failureEl = document.querySelector('#kpiFailure .value');
      failureEl.textContent = `${failure.toFixed(2)}%`;
      const trend = document.querySelector('#trendingFailure');
      trend.textContent = failure < 2 ? 'Low risk' : failure < 5 ? 'Moderate' : 'High risk';
      trend.className = `trend ${failure > 5 ? 'down' : 'up'}`;
      if (failure < 2) trend.style.color = 'var(--accent-green)';
      else if (failure < 5) trend.style.color = 'var(--accent-amber)';
      else trend.style.color = 'var(--accent-red)';
    }

    function buildRiskChart(history) {
      const totals = { LOW: 0, MEDIUM: 0, HIGH: 0, CRITICAL: 0 };
      history.forEach(item => totals[item.risk_level] = (totals[item.risk_level] || 0) + 1);
      const data = [totals.LOW, totals.MEDIUM, totals.HIGH, totals.CRITICAL];
      const ctx = document.getElementById('riskDoughnut').getContext('2d');
      window.riskDoughnutChart?.destroy();
      window.riskDoughnutChart = new Chart(ctx, {
        type: 'doughnut', data: { labels: ['Low','Medium','High','Critical'], datasets:[{ data, backgroundColor:['var(--accent-green)','var(--accent-cyan)','var(--accent-amber)','var(--accent-red)'], borderWidth: 0 }] }, options: { responsive:true, plugins:{ legend:{ position:'bottom', labels:{ color:'var(--text-secondary)' }}, tooltip:{ callbacks:{ label: ctx => `${ctx.label}: ${ctx.formattedValue}` } } }}
      });
    }

    function buildSensorChart(readings) {
      const labels = readings.map(item => new Date(item.created_at || item.created_at).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})).reverse();
      const speed = readings.map(item => item.rotational_speed_rpm || 0).reverse();
      const torque = readings.map(item => item.torque_nm || 0).reverse();
      const ctx = document.getElementById('sensorLine').getContext('2d');
      window.sensorLineChart?.destroy();
      window.sensorLineChart = new Chart(ctx, {
        type: 'line', data: { labels, datasets:[{ label:'Rotational Speed', data: speed, borderColor:'var(--accent-cyan)', backgroundColor:createGradient(ctx,'cyan'), tension:0.4, fill:true, pointRadius:0 },{ label:'Torque', data: torque, borderColor:'var(--accent-amber)', backgroundColor:createGradient(ctx,'amber'), tension:0.4, fill:true, pointRadius:0 }] }, options:{ responsive:true, scales:{ x:{ ticks:{ color:'var(--text-secondary)' }, grid:{ color:'rgba(255,255,255,0.04)' } }, y:{ ticks:{ color:'var(--text-secondary)' }, grid:{ color:'rgba(255,255,255,0.04)' } } }, plugins:{ legend:{ labels:{ color:'var(--text-secondary)' } } } }
      });
    }

    function createGradient(ctx, color) {
      const gradient = ctx.createLinearGradient(0, 0, 0, 260);
      if (color === 'cyan') { gradient.addColorStop(0,'rgba(0,212,255,0.35)'); gradient.addColorStop(1,'rgba(0,212,255,0.03)'); }
      else { gradient.addColorStop(0,'rgba(245,158,11,0.28)'); gradient.addColorStop(1,'rgba(245,158,11,0.02)'); }
      return gradient;
    }

    function buildAlerts() {
      const container = document.getElementById('alertFeed');
      container.innerHTML = '<div class="alert-empty"><strong>Loading active alerts...</strong></div>';
      safeFetch(`${API_BASE}/predict/alerts?resolved=false&limit=10`, []).then(alerts => {
        if (!alerts.length) { container.innerHTML = '<div class="alert-empty"><strong>No active alerts — all systems nominal</strong><span>All systems are stable and running within expected thresholds.</span></div>'; return; }
        container.innerHTML = '';
        alerts.forEach(alert => container.appendChild(createAlertRow(alert)));
      });
    }

    function createAlertRow(alert) {
      const row = document.createElement('div');
      row.className = `alert-row ${alert.severity === 'CRITICAL' ? 'critical' : ''}`;
      row.innerHTML = `<div class="badge ${alert.severity === 'CRITICAL' ? 'red' : 'amber'}">${alert.severity}</div><div class="alert-meta"><div class="alert-title"><strong>${alert.machine_id || 'Machine'}</strong></div><div class="alert-copy">${truncate(alert.message || '', 80)}</div><div class="alert-time">${formatRelative(alert.created_at || alert.timestamp || '')}</div></div><div>${alert.alert_type || 'Predictive Failure'}</div><button class="alert-resolve">Resolve</button>`;
      row.querySelector('.alert-resolve').addEventListener('click', () => resolveAlert(alert.id, row));
      return row;
    }

    async function resolveAlert(alertId, row) {
      try {
        await safeFetch(`${API_BASE}/predict/alerts`, { method:'PATCH', body: JSON.stringify({ id: alertId, resolved: true }), headers:{ 'Content-Type':'application/json' } });
        row.style.opacity = '0.3';
        row.querySelector('.alert-resolve').textContent = 'Resolved';
        row.querySelector('.alert-resolve').disabled = true;
      } catch (err) { console.warn('Resolve failed', err); }
    }

    function truncate(text, length) { return text.length > length ? text.slice(0, length) + '…' : text; }
    function formatRelative(value) { if (!value) return 'Just now'; const diff = Math.max(0, Date.now() - new Date(value).getTime()); const minutes = Math.floor(diff / 60000); return minutes === 0 ? 'Just now' : `${minutes} mins ago`; }

    async function fetchPredictHistory() {
      const history = await safeFetch(`${API_BASE}/predict/history?limit=10`, []);
      const tbody = document.getElementById('historyTable');
      tbody.innerHTML = history.map(item => `<tr><td>${item.id || '—'}</td><td><span class="table-badge ${item.risk_level?.toLowerCase() || 'low'}">${item.risk_level || 'UNKNOWN'}</span></td><td>${((item.failure_probability||0)*100).toFixed(1)}%</td><td>${item.failure_predicted ? 'Yes' : 'No'}</td><td>${formatRelative(item.created_at||item.timestamp)}</td></tr>`).join('');
      buildPredictionGauge();
    }

    function buildPredictionGauge() {
      const svg = document.getElementById('fullRiskGauge');
      svg.innerHTML = '';
      const gauge = createGauge(0, svg);
      gauge.update(0);
    }

    function createGauge(value, svg) {
      const radius = 130; const center = 160; const arc = document.createElementNS('http://www.w3.org/2000/svg','path'); const track = document.createElementNS('http://www.w3.org/2000/svg','path'); track.setAttribute('d', describeArc(center, center, radius, 180, 0)); track.setAttribute('fill','none'); track.setAttribute('stroke','rgba(255,255,255,0.08)'); track.setAttribute('stroke-width','18'); svg.appendChild(track); arc.setAttribute('fill','none'); arc.setAttribute('stroke-linecap','round'); arc.setAttribute('stroke-width','18'); svg.appendChild(arc); const needle = document.createElementNS('http://www.w3.org/2000/svg','line'); needle.setAttribute('x1', center); needle.setAttribute('y1', center); needle.setAttribute('x2', center); needle.setAttribute('y2', center-118); needle.setAttribute('stroke','#00d4ff'); needle.setAttribute('stroke-width','4'); svg.appendChild(needle);
      return { update(score) { const endAngle = 180 - Math.min(Math.max(score,0),100) * 1.8; arc.setAttribute('d', describeArc(center, center, radius, 180, endAngle)); const color = score < 25 ? '#10b981' : score < 50 ? '#00d4ff' : score < 75 ? '#f59e0b' : '#ef4444'; arc.setAttribute('stroke', color); const rad = (endAngle * Math.PI) / 180; const x = center + Math.cos(rad) * 110; const y = center + Math.sin(rad) * 110; needle.setAttribute('x2', x); needle.setAttribute('y2', y); } };
    }

    function describeArc(x, y, radius, startAngle, endAngle){ const start = polarToCartesian(x,y,radius,endAngle); const end = polarToCartesian(x,y,radius,startAngle); const largeArcFlag = endAngle - startAngle <= 180 ? '0':'1'; return ['M',start.x,start.y,'A',radius,radius,0,largeArcFlag,0,end.x,end.y].join(' '); }
    function polarToCartesian(centerX, centerY, radius, angleInDegrees){ const angleInRadians = (angleInDegrees-90)*Math.PI/180; return { x:centerX + radius*Math.cos(angleInRadians), y:centerY + radius*Math.sin(angleInRadians) }; }

    function loadAgentChat() {
      renderAgentCards();
      setChatOptions();
      fetchAgentStatus();
      if (!document.getElementById('chatBox').innerHTML) { addMessage('agent', 'Maintenance Technician','Welcome to the AI operations desk. Ask a question to begin.'); }
    }

    function renderAgentCards() {
      const config = [
        { name:'Maintenance Technician', icon:'🛠', tagline:'SOPs & Repair Procedures', key:'maintenance' },
        { name:'Analytics Specialist', icon:'📊', tagline:'Production Insights & Trends', key:'analytics' },
        { name:'ML Systems Analyst', icon:'🧠', tagline:'Model Explanations & Risk Analysis', key:'ml' }
      ];
      const container = document.getElementById('agentCards'); container.innerHTML = '';
      config.forEach(agent => {
        const card = document.createElement('div');
        card.className = 'agent-card' + (state.agentKey === agent.key ? ' active' : '');
        card.innerHTML = `<div class="agent-icon">${agent.icon}</div><div class="agent-name">${agent.name}</div><div class="agent-tagline">${agent.tagline}</div><div class="badge cyan">${state.agentKey===agent.key ? 'ACTIVE':'SELECT'}</div>`;
        card.addEventListener('click', () => { state.agentKey = agent.key; state.activeAgent = agent.name; document.querySelectorAll('.agent-card').forEach(el=>el.classList.remove('active')); card.classList.add('active'); updateAgentPanel(agent); });
        container.appendChild(card);
      });
      updateAgentPanel(config.find(a => a.key === state.agentKey));
    }

    function updateAgentPanel(agent) {
      document.getElementById('currentAgentName').textContent = agent.name;
      document.getElementById('agentCapability').textContent = agent.tagline;
      document.getElementById('agentUsed').textContent = agent.name;
    }

    function setChatOptions() {
      const chips = document.getElementById('chatChips'); chips.innerHTML = '';
      ['How do I replace a bearing?','Why did downtime increase?','What is Machine H99999\'s risk?','Explain the latest prediction'].forEach(label => {
        const chip = document.createElement('div'); chip.className='chip'; chip.textContent=label; chip.addEventListener('click',()=>{ document.getElementById('chatInput').value=label; }); chips.appendChild(chip); });
      document.getElementById('chatSendBtn').addEventListener('click', sendChat);
    }

    async function sendChat() {
      const input = document.getElementById('chatInput'); const message = input.value.trim(); if (!message) return;
      addMessage('user','You',message);
      input.value='';
      const loading = addLoadingMessage();
      const payload = { question: message, context: { agent_preference: state.agentKey }};
      const response = await safeFetch(`${API_BASE}/agent/query`, { method:'POST', body: JSON.stringify(payload), headers:{ 'Content-Type':'application/json' } }, { answer:'Unable to reach agent.', agent_used:'none', timestamp:new Date().toISOString(), status:'ERROR' });
      loading.remove();
      addMessage('agent', response.agent_used || state.activeAgent, response.answer || 'No response available.');
      document.getElementById('agentStatus').textContent = response.status === 'READY' ? 'Ready' : 'Unavailable';
      document.getElementById('agentLatency').textContent = '0.8s';
    }

    function addMessage(role, sender, text) {
      const box = document.getElementById('chatBox'); const message = document.createElement('div'); message.className = `message ${role}`; message.innerHTML = `<div class="message-meta"><strong>${sender}</strong><span>${new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}</span></div><div>${text}</div>`; box.appendChild(message); box.scrollTop = box.scrollHeight;
    }

    function addLoadingMessage() { const box = document.getElementById('chatBox'); const message = document.createElement('div'); message.className='message agent'; message.innerHTML = `<div class="message-meta"><strong>${state.activeAgent}</strong><span>Typing...</span></div><div class="typing-dots"><span></span><span></span><span></span></div>`; box.appendChild(message); box.scrollTop = box.scrollHeight; return message; }

    function fetchAgentStatus() { safeFetch(`${API_BASE}/agent/status`, { available_agents:[], status:'CREDENTIALS_REQUIRED', credentials_configured:false }).then(status => { document.getElementById('svcAgent').textContent = status.status || 'UNKNOWN'; document.getElementById('svcAgentConf').textContent = status.credentials_configured ? 'Configured' : 'Not configured'; }); }

    function checkApiStatus() {
      safeFetch(`${API_BASE}/health`, { status: 'ERROR' })
        .then(data => {
          const dot = document.getElementById('apiStatusDot');
          const text = document.getElementById('apiStatusText');
          if (!dot) return;
          const ok = (data.status === 'OK' || data.status === 'healthy' || data.status === 'HEALTHY');
          if (ok) {
            dot.classList.add('online');
            dot.classList.remove('offline');
            if (text) text.textContent = 'API Online';
          } else {
            dot.classList.add('offline');
            dot.classList.remove('online');
            if (text) text.textContent = 'API Offline';
          }
        })
        .catch(() => {
          const dot = document.getElementById('apiStatusDot');
          const text = document.getElementById('apiStatusText');
          if (!dot) return;
          dot.classList.add('offline');
          dot.classList.remove('online');
          if (text) text.textContent = 'API Offline';
        });
    }

    function buildSearchSuggestions() { const suggestions = ['Bearing Replacement','Overheating Diagnosis','Torque Specifications','Emergency Shutdown','Vibration Thresholds','Lubrication Schedule']; const container = document.getElementById('searchSuggestions'); container.innerHTML = suggestions.map(text => `<div class="pill" data-query="${text}">${text}</div>`).join(''); container.querySelectorAll('.pill').forEach(el => el.addEventListener('click', () => { document.getElementById('docSearchInput').value = el.dataset.query; runDocumentSearch(); })); document.getElementById('docSearchBtn').addEventListener('click', runDocumentSearch); document.getElementById('docSearchInput').addEventListener('keydown', e=>{ if(e.key==='Enter') runDocumentSearch(); }); }

    async function runDocumentSearch() { const q = document.getElementById('docSearchInput').value.trim(); const results = q ? await safeFetch(`${API_BASE}/search/documents?q=${encodeURIComponent(q)}&limit=5`, { results:[] }) : { results: [] }; const container = document.getElementById('searchResults'); if (!q) { container.innerHTML = '<div class="alert-empty"><strong>Enter a query to search maintenance documentation</strong></div>'; return; } if (!results.results.length) { container.innerHTML = '<div class="alert-empty"><strong>No documents found</strong></div>'; return; } container.innerHTML = results.results.map(item => `<div class="result-card"><div class="result-title"><span>${item.source || 'Manual'}</span><small>${item.score ? `${(item.score*100).toFixed(0)}%` : 'N/A'}</small></div><p class="result-copy">${truncate(item.preview || item.text || 'No preview available.', 180)}</p><div class="result-actions"><button class="result-btn" onclick="document.querySelector('#searchPage').scrollIntoView({ behavior:'smooth' })">Expand</button><button class="result-btn" onclick="copySearchContext('${item.id || ''}')">Ask Agent</button></div></div>`).join(''); }

    function copySearchContext(id) { addMessage('agent', state.activeAgent, `Ask Agent about document ID ${id}.`); }

    async function refreshSystemStatus() {
      const health = await safeFetch(`${API_BASE}/health`, { status:'ERROR' });
      const config = await safeFetch(`${API_BASE}/system/config`, {});
      const rag = await safeFetch(`${API_BASE}/search/documents/health`, { rag_initialized:false, documents_indexed:0, status:'ERROR' });
      document.getElementById('svcBackend').textContent = health.status || 'ERROR'; document.getElementById('svcBackendAt').textContent = new Date(health.timestamp||Date.now()).toLocaleTimeString(); document.getElementById('svcDatabase').textContent = health.database || 'connected'; document.getElementById('svcDatabaseAt').textContent = new Date().toLocaleTimeString(); document.getElementById('svcRag').textContent = rag.status || 'ERROR'; document.getElementById('svcRagCount').textContent = rag.documents_indexed || '0'; document.getElementById('svcAzureOpenAI').textContent = config.azure_openai_configured ? 'Configured':'Not configured'; document.getElementById('svcAzureSearch').textContent = config.azure_search_configured ? 'Configured':'Not configured'; document.getElementById('svcAzureKeyVault').textContent = config.azure_key_vault_configured ? 'Configured':'Not configured'; const table = document.getElementById('configTable'); table.innerHTML = Object.entries(config).map(([key,value]) => `<tr><td class="config-key">${key}</td><td class="config-val">${String(value)}</td></tr>`).join(''); }

    async function safeFetch(url, arg1 = {}, arg2 = {}) {
      let opts = {};
      let fallback = {};
      if (arg1 && (arg1.method || arg1.body || arg1.headers)) {
        opts = arg1;
        fallback = arg2;
      } else {
        fallback = arg1;
        opts = arg2;
      }
      try {
        const response = await fetch(url, Object.keys(opts).length ? opts : undefined);
        if (!response.ok) return fallback;
        return response.json();
      } catch (e) {
        return fallback;
      }
    }

    function addPredictedFactors(chartId, labels, values) {
      const ctx = document.getElementById(chartId).getContext('2d');
      return new Chart(ctx, { type:'bar', data:{ labels, datasets:[{ data: values, backgroundColor:'rgba(0,212,255,0.54)', borderRadius: 12 }] }, options:{ indexAxis:'y', responsive:true, scales:{ x:{ display:false }, y:{ ticks:{ color:'var(--text-secondary)' } } }, plugins:{ legend:{ display:false } } } });
    }

    function setupPredictionControls() {
      setRangeControls(['quickAir','quickProcess','quickSpeed','quickTorque','quickWear','fullAir','fullProcess','fullSpeed','fullTorque','fullWear']);
      const qBtn = document.getElementById('quickPredictBtn');
      const fBtn = document.getElementById('fullPredictBtn');
      if (qBtn) qBtn.addEventListener('click', runQuickPredict);
      if (fBtn) fBtn.addEventListener('click', runFullPredict);
    }

    async function runQuickPredict() { const payload = buildPredictionPayload('quick'); await runPrediction(payload, 'quick'); }
    async function runFullPredict() { const payload = buildPredictionPayload('full'); await runPrediction(payload, 'full'); }

    function buildPredictionPayload(prefix) {
      return { sensor_data: { air_temp_k: Number(document.getElementById(`${prefix}Air`).value), process_temp_k: Number(document.getElementById(`${prefix}Process`).value), rotational_speed_rpm: Number(document.getElementById(`${prefix}Speed`).value), torque_nm: Number(document.getElementById(`${prefix}Torque`).value), tool_wear_min: Number(document.getElementById(`${prefix}Wear`).value), product_id: 'MACHINE-001', type: state[prefix==='quick' ? 'type' : 'fullType'] }, save_to_db: true };
    }

    async function runPrediction(payload, prefix) {
      const result = await safeFetch(`${API_BASE}/predict/failure`, { method:'POST', body: JSON.stringify(payload), headers:{ 'Content-Type':'application/json' } }, { failure_probability:0, risk_level:'UNKNOWN', explanation:'No response.' });
      displayPrediction(result, prefix);
    }

    function displayPrediction(result, prefix) {
      const score = Math.round((result.failure_probability || 0) * 100);
      const badge = score < 25 ? 'green' : score < 50 ? 'cyan' : score < 75 ? 'amber' : 'red';
      const text = score < 25 ? 'Low risk detected' : score < 50 ? 'Caution advised' : score < 75 ? 'Elevated failure risk' : 'Critical risk';
      const label = document.getElementById(prefix === 'quick' ? 'quickRiskText' : 'fullPredictionSummary');
      const scoreEl = prefix === 'quick' ? document.getElementById('quickRiskScore') : null;
      const badgeEl = document.getElementById(prefix === 'quick' ? 'quickRiskText' : 'fullRiskBadge');
      if (scoreEl) {
        scoreEl.textContent = `${score}%`;
      }
      if (prefix === 'quick') {
        badgeEl.textContent = text;
      } else {
        badgeEl.textContent = result.risk_level || 'UNKNOWN';
        badgeEl.className = `badge ${badge}`;
      }
      label.textContent = result.explanation || text;
      const factors = result.top_contributing_features || ['Load variances','Temperature drift','Wear pattern'];
      const values = factors.map((_, index) => 80 - index * 15);
      window[`factorChart_${prefix}`]?.destroy();
      window[`factorChart_${prefix}`] = addPredictedFactors(prefix==='quick' ? 'quickFactors' : 'fullFactorChart', factors, values);
      animateGauge(prefix === 'quick' ? 'quickRiskScore' : 'fullRiskGauge', score);
    }

    function animateGauge(targetId, value) { if (targetId === 'quickRiskScore') { return; } const svg = document.getElementById('fullRiskGauge'); svg.innerHTML = ''; const gauge = createGauge(0, svg); gauge.update(value); }

    function animateActiveAlerts() {
      document.querySelectorAll('.alert-row.critical').forEach(row => row.classList.add('critical'));
    }

    function showPage(pageId) {
      document.querySelectorAll('.page').forEach(p => {
        p.classList.remove('active');
      });
      const target = document.getElementById(pageId);
      if (target) {
        target.classList.add('active');
      }
    }

    function initRoutes() { const hash = window.location.hash.replace('#',''); const page = hash ? pageIdFromHash(hash) : 'dashboardPage'; navigate(page); }
    function pageIdFromHash(hash) { return NAV_ITEMS.find(item => item.label.toLowerCase() === hash.toLowerCase())?.page || 'dashboardPage'; }

    // On load
    document.addEventListener('DOMContentLoaded', () => {
      console.log('🚀 Initializing ManuAI platform...');

      try {
        const statusText = document.getElementById('apiStatusText');
        if (statusText) statusText.textContent = 'Initializing...';

        // Navigation wiring
        createNav();

        // Slider + predict button wiring
        setupPredictionControls();

        // Type buttons for quick/full predict panels
        createTypeButtons('quickTypeButtons', 'type');
        createTypeButtons('fullTypeButtons', 'fullType');

        // Search suggestions
        buildSearchSuggestions();

        // Hero counter animations
        buildHero();

        // Agent chat panel (only populates cards, doesn't open page)
        renderAgentCards();
        setChatOptions();
        fetchAgentStatus();

        // Wire refresh status btn
        const refreshBtn = document.getElementById('refreshStatusBtn');
        if (refreshBtn) refreshBtn.addEventListener('click', refreshSystemStatus);

        // Wire Enter key for chat
        const chatInput = document.getElementById('chatInput');
        if (chatInput) {
          chatInput.addEventListener('keydown', e => {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChat(); }
          });
        }

        // API health polling
        checkApiStatus();
        setInterval(checkApiStatus, 30000);

        // Dashboard auto-refresh
        setInterval(() => {
          const dashboard = document.getElementById('dashboardPage');
          if (dashboard && dashboard.classList.contains('active')) fetchDashboard();
        }, 30000);

        // Navigate to dashboard (triggers fetchDashboard + fetchPredictHistory)
        navigate('dashboardPage');

        console.log('✅ ManuAI platform ready');
      } catch (error) {
        console.error('❌ Init error:', error);
        showFatal('Init failed: ' + error.message);
      }
    });

    function debounce(fn, delay) { let timer; return (...args) => { clearTimeout(timer); timer = setTimeout(() => fn(...args), delay); }; }
  </script>
</body>
</html>
